<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Demo_FinalProject.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Demo_FinalProject.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource Primary}"
    Shell.ForegroundColor="{StaticResource OnPrimary}"
    Shell.TabBarBackgroundColor="{StaticResource Surface}"
    Shell.TabBarTitleColor="{StaticResource Primary}">

    <ShellContent
        Title="Login"
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.FlyoutItemIsVisible="False"
        Shell.TabBarIsVisible="False" />

    <TabBar Route="inicio">
        <ShellContent Title="Inicio" Route="home"
                      ContentTemplate="{DataTemplate views:InicioPage}" />
        <ShellContent Title="Materias" Route="materias"
                      ContentTemplate="{DataTemplate views:MateriasPage}" />
        <ShellContent Title="Perfil" Route="perfil"
                      ContentTemplate="{DataTemplate views:PerfilPage}" />
    </TabBar>

</Shell>
