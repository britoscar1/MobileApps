<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Demo_SensorImpl.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Demo_SensorImpl.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource Primary}"
    Shell.ForegroundColor="{StaticResource OnPrimary}">

    <TabBar>
        <ShellContent Title="Camara" Route="camera"
                      ContentTemplate="{DataTemplate views:CameraPage}" />
        <ShellContent Title="GPS" Route="gps"
                      ContentTemplate="{DataTemplate views:GpsPage}" />
        <ShellContent Title="Acelerometro" Route="accelerometer"
                      ContentTemplate="{DataTemplate views:AccelerometerPage}" />
    </TabBar>

</Shell>
