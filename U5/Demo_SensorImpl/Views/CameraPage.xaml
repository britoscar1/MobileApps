<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Demo_SensorImpl.ViewModels"
    x:Class="Demo_SensorImpl.Views.CameraPage"
    x:DataType="vm:CameraViewModel"
    Title="Camara"
    BackgroundColor="{StaticResource Background}">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <Label Text="Captura de Foto" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Tomar foto" Command="{Binding TomarFotoCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}" CornerRadius="8" />
                <Button Grid.Column="1" Text="Galeria" Command="{Binding SeleccionarFotoCommand}"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource Primary}" CornerRadius="8"
                        BorderColor="{StaticResource Primary}" BorderWidth="1" />
            </Grid>

            <Label Text="{Binding Estado}" FontSize="14"
                   TextColor="{StaticResource OnSurfaceVariant}" />

            <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource Outline}"
                    BackgroundColor="{StaticResource Surface}"
                    HeightRequest="300" Padding="8">
                <Image Source="{Binding FotoCapturada}" Aspect="AspectFit" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
