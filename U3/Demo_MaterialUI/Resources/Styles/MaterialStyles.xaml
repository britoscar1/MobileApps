<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Material Design 3 Typography Scale -->
    <!-- Reference: https://m3.material.io/styles/typography/overview -->

    <!-- Display -->
    <Style TargetType="Label" x:Key="DisplayLarge">
        <Setter Property="FontSize" Value="57" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.12" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="DisplayMedium">
        <Setter Property="FontSize" Value="45" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.16" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="DisplaySmall">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.22" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <!-- Headline -->
    <Style TargetType="Label" x:Key="HeadlineLarge">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="HeadlineMedium">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.29" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="HeadlineSmall">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <!-- Title -->
    <Style TargetType="Label" x:Key="TitleLarge">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="TitleMedium">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="TitleSmall">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.43" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <!-- Body -->
    <Style TargetType="Label" x:Key="BodyLarge">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="LineHeight" Value="1.5" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="BodyMedium">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="LineHeight" Value="1.43" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="BodySmall">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="None" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <!-- Label (pequeños textos enfatizados) -->
    <Style TargetType="Label" x:Key="LabelLarge">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.43" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="LabelMedium">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.33" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>

    <Style TargetType="Label" x:Key="LabelSmall">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineHeight" Value="1.27" />
        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    </Style>


    <!-- MD3 Component Styles -->

    <!-- TextField: Border que envuelve un Entry -->
    <Style TargetType="Border" x:Key="MD3TextField">
        <Setter Property="Stroke" Value="{StaticResource Outline}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- Card: Border elevado con fondo Surface -->
    <Style TargetType="Border" x:Key="MD3Card">
        <Setter Property="Stroke" Value="{StaticResource Outline}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- TopAppBar: franja de encabezado -->
    <Style TargetType="Border" x:Key="MD3TopAppBar">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <!-- FilledButton: fondo Primary, texto OnPrimary, esquinas 20dp -->
    <Style TargetType="Button" x:Key="FilledButton">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource OnPrimary}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}" />
                            <Setter Property="Opacity" Value="0.88" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Outline}" />
                            <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- OutlinedButton: fondo transparente, borde y texto Primary -->
    <Style TargetType="Button" x:Key="OutlinedButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BorderColor" Value="{StaticResource PrimaryDark}" />
                            <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.88" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BorderColor" Value="{StaticResource Outline}" />
                            <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- TextButton: sin fondo ni borde, solo texto Primary -->
    <Style TargetType="Button" x:Key="TextButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource PrimaryDark}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.88" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

</ResourceDictionary>
