<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Link.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Link.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource Surface}"
    Shell.ForegroundColor="{StaticResource OnSurface}"
    Shell.TitleColor="{StaticResource OnSurface}"
    Shell.TabBarBackgroundColor="{StaticResource Surface}"
    Shell.TabBarTitleColor="{StaticResource Primary}"
    Title="Link">

    <!-- Login fuera del TabBar (ruta absoluta inicial). -->
    <ShellContent
        Title="Login"
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.FlyoutItemIsVisible="False"
        Shell.TabBarIsVisible="False" />

    <TabBar Route="inicio">
        <ShellContent
            Title="Inicio"
            Route="home"
            ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent
            Title="Materias"
            Route="materias"
            ContentTemplate="{DataTemplate views:MateriasPage}" />
        <ShellContent
            Title="Perfil"
            Route="perfil"
            ContentTemplate="{DataTemplate views:PerfilPage}" />
    </TabBar>

</Shell>
