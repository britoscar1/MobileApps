<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Link.ViewModels"
             x:Class="Link.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{Binding Saludo}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}" />

            <Label Text="Bienvenido a Link. Aqui veras tus materias y asistencias proximamente."
                   FontSize="14"
                   TextColor="{StaticResource OnSurfaceVariant}" />

            <Border Stroke="{StaticResource Outline}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Registro de Asistencia"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurface}" />
                    <Label Text="Escanea el codigo QR proporcionado por tu docente para registrar tu asistencia."
                           FontSize="13"
                           TextColor="{StaticResource OnSurfaceVariant}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Escanear QR"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource OnPrimary}"
                    CornerRadius="8"
                    FontSize="16"
                    HeightRequest="50"
                    Clicked="OnEscanerClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
