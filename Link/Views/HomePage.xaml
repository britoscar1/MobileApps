<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Link.ViewModels"
             x:Class="Link.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{Binding Saludo}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}" />

            <Label Text="Bienvenido a Link. Aqui veras tus materias y asistencias proximamente."
                   FontSize="14"
                   TextColor="{StaticResource OnSurfaceVariant}" />

            <Border Stroke="{StaticResource Outline}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Estado del proyecto"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurface}" />
                    <Label Text="U1-U3 listas. U4 (persistencia + listas) y U5 (camara/QR/sensores) en desarrollo."
                           FontSize="13"
                           TextColor="{StaticResource OnSurfaceVariant}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
