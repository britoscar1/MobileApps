<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Link.ViewModels"
             xmlns:m="clr-namespace:Link.Models"
             x:Class="Link.Views.MateriasPage"
             x:DataType="vm:MateriasViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <CollectionView ItemsSource="{Binding Materias}" Margin="16">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="m:Materia">
                <Border Stroke="{StaticResource Outline}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Nombre}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <Label Text="{Binding Codigo}"
                               FontSize="12"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                        <Label Text="{Binding Docente, StringFormat='Docente: {0}'}"
                               FontSize="12"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
