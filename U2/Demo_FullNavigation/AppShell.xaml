<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Demo_FullNavigation.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Demo_FullNavigation.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource Surface}"
    Shell.ForegroundColor="{StaticResource OnSurface}"
    Shell.TitleColor="{StaticResource OnSurface}"
    Shell.TabBarBackgroundColor="{StaticResource Surface}"
    Shell.TabBarTitleColor="{StaticResource Primary}"
    Title="Full Navigation">

    <ShellContent
        Title="Login"
        Route="login"
        ContentTemplate="{DataTemplate pages:LoginPage}"
        Shell.TabBarIsVisible="False" />

    <TabBar Route="inicio">
        <ShellContent Title="Inicio"
                      Route="home"
                      ContentTemplate="{DataTemplate pages:HomePage}" />
        <ShellContent Title="Materias"
                      Route="materias"
                      ContentTemplate="{DataTemplate pages:MateriasPage}" />
        <ShellContent Title="Perfil"
                      Route="perfil"
                      ContentTemplate="{DataTemplate pages:PerfilPage}" />
    </TabBar>

</Shell>
