<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Demo_IntentDataPassing.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Demo_IntentDataPassing.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource Surface}"
    Shell.ForegroundColor="{StaticResource OnSurface}"
    Shell.TitleColor="{StaticResource OnSurface}"
    Title="Intent Data Passing">

    <ShellContent
        Title="Login"
        Route="login"
        ContentTemplate="{DataTemplate pages:LoginPage}" />

</Shell>
