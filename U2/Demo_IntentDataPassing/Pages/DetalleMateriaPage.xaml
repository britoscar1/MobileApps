<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Demo_IntentDataPassing.Pages.DetalleMateriaPage"
             Title="Detalle"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label x:Name="NombreLabel" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}" />
            <Label x:Name="IdLabel" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" />

            <Border Stroke="{StaticResource Outline}" StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Docente" FontSize="12"
                           TextColor="{StaticResource OnSurfaceVariant}" />
                    <Label x:Name="DocenteLabel" FontSize="14"
                           TextColor="{StaticResource OnSurface}" />

                    <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,4" />

                    <Label Text="Aula" FontSize="12"
                           TextColor="{StaticResource OnSurfaceVariant}" />
                    <Label x:Name="AulaLabel" FontSize="14"
                           TextColor="{StaticResource OnSurface}" />

                    <BoxView HeightRequest="1" Color="{StaticResource Outline}" Margin="0,4" />

                    <Label Text="Horario" FontSize="12"
                           TextColor="{StaticResource OnSurfaceVariant}" />
                    <Label x:Name="HorarioLabel" FontSize="14"
                           TextColor="{StaticResource OnSurface}" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ErrorLabel"
                   TextColor="{StaticResource Error}"
                   FontSize="13"
                   IsVisible="False" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
