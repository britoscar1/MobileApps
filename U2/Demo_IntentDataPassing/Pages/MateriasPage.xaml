<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:Demo_IntentDataPassing.Models"
             x:Class="Demo_IntentDataPassing.Pages.MateriasPage"
             Title="Materias"
             BackgroundColor="{StaticResource Background}">

    <CollectionView x:Name="MateriasList" Margin="16" SelectionMode="Single"
                    SelectionChanged="OnMateriaSeleccionada">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="m:Materia">
                <Border Stroke="{StaticResource Outline}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="16" Margin="0,0,0,12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <Label Text="{Binding Id}" FontSize="12"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                        <Label Text="{Binding Docente}" FontSize="12"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
