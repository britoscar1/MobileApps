<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Demo_PersistentData.ViewModels"
    xmlns:models="clr-namespace:Demo_PersistentData.Models"
    x:Class="Demo_PersistentData.Views.SesionesPage"
    x:DataType="vm:SesionesViewModel"
    Title="Sesiones de Clase"
    BackgroundColor="{StaticResource Background}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto">
            <Label Text="Sesiones de Clase" FontSize="20" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="+" FontSize="24"
                    Command="{Binding IrANuevaCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource OnPrimary}"
                    CornerRadius="20" WidthRequest="40" HeightRequest="40"
                    Padding="0" />
        </Grid>
    </Shell.TitleView>

    <Grid>
        <Label Text="No hay sesiones registradas. Presiona + para agregar."
               IsVisible="{Binding SinSesiones}"
               HorizontalOptions="Center" VerticalOptions="Center"
               TextColor="{StaticResource OnSurfaceVariant}" FontSize="16" />

        <RefreshView Command="{Binding CargarSesionesCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Sesiones}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SesionClase">
                        <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource Outline}"
                                BackgroundColor="{StaticResource Surface}" Padding="16" Margin="16,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SesionesViewModel}}, Path=VerDetalleCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding NombreMateria}" FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <Label Grid.Column="1"
                                       Text="{Binding PorcentajeAsistencia, StringFormat='{0:F0}%'}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy}'}"
                                       FontSize="13" TextColor="{StaticResource OnSurfaceVariant}"
                                       Margin="0,4,0,0" />
                                <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                                             Progress="{Binding PorcentajeAsistencia, Converter={StaticResource PercentToProgressConverter}}"
                                             ProgressColor="{StaticResource Primary}"
                                             Margin="0,6,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
